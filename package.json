{
  "name": "menus-print-bridge",
  "version": "1.0.2",
  "description": "Print bridge for Menus by Baseup Operations",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "kitchen.menus.print-bridge",
    "productName": "Menus Print Bridge",
    "files": [
      "main.js",
      "bridge.js",
      "ui/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64",
            "armv7l"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "executableArgs": [
        "--no-sandbox"
      ]
    }
  }
}
